# Supabase Konfiguration
# Diese Werte findest du in deinem Supabase-Dashboard unter: Settings > API

# URL deines Supabase-Projekts (z.B. https://dein-projekt.supabase.co oder http://dein-server:8000)
VITE_SUPABASE_URL="https://DEIN-PROJEKT.supabase.co"

# Anon/Public Key deines Supabase-Projekts
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# (Optional) Supabase Projekt-ID - nur fuer lokale Supabase CLI Nutzung benoetigt
VITE_SUPABASE_PROJECT_ID="dein-projekt-id"
